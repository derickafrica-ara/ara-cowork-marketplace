<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.ara.pulse-server</string>
  <key>ProgramArguments</key>
  <array>
    <string>__PYTHON__</string>
    <string>__SERVER__</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>__HOME__/Library/Logs/ara-pulse-server/out.log</string>
  <key>StandardErrorPath</key>
  <string>__HOME__/Library/Logs/ara-pulse-server/err.log</string>
</dict>
</plist>
